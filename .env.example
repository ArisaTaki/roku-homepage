# Optional browser-facing endpoint.
# Leave blank for static hosting / pure local KB mode.
# Use /api/iroha-assistant when running Vite dev/preview or deploying the included serverless function.
VITE_IROP_ASSISTANT_ENDPOINT=

# Server-only settings for api/iroha-assistant.ts.
# Keep real values out of the browser and out of git.
# With only AI_API_KEY set, the included endpoint defaults to:
# AI_CHAT_COMPLETIONS_ENDPOINT=https://api.deepseek.com/chat/completions
# AI_MODEL=deepseek-v4-flash
# AI_THINKING=disabled keeps the small website assistant fast and avoids reasoning-only replies.
AI_API_KEY=
AI_MODEL=
AI_CHAT_COMPLETIONS_ENDPOINT=
AI_THINKING=disabled
AI_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_WINDOW_HOURS=6
AI_TIMEOUT_MS=12000

# Optional: real nature-live2d demo data source.
# Uses AI_API_KEY by default for DeepSeek-compatible intent analysis.
NATURE_LIVE2D_PROJECT_DIR=/Users/hacchiroku/AI/nature-live2d
NATURE_LIVE2D_MODEL=
NATURE_LIVE2D_ENDPOINT=
NATURE_LIVE2D_API_KEY=
NATURE_LIVE2D_TIMEOUT_MS=12000
