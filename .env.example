# Optional browser-facing endpoint. Leave blank for pure local KB mode.
# Use /api/iroha-assistant when deploying the included serverless function.
VITE_IROP_ASSISTANT_ENDPOINT=/api/iroha-assistant

# Server-only settings for api/iroha-assistant.js.
# Keep real values out of the browser and out of git.
AI_CHAT_COMPLETIONS_ENDPOINT=
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_MS=12000
